import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
        List<Integer> list=new ArrayList<>();
        list.add(10);
        list.add(11);
        list.add(12);
        //ListIterator to iterate for list
        ListIterator<Integer> it=list.listIterator();//Traversal not started yet
        //Forward Traversal
        while(it.hasNext()){//it is used to move until end
            it.next();
        }
        //Backward Traversal
        while(it.hasPrevious()){
            System.out.println(it.previous());//from end to start
        }
        //System.out.println(list);
        
	}
}
